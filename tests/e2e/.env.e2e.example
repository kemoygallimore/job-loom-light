# Copy to .env.e2e and fill in. Do NOT commit .env.e2e.

# Where the app is running (vite dev default for this app is commonly 8080).
E2E_BASE_URL=http://localhost:8080

# A seeded HR admin account in your TEST Supabase project (never production).
E2E_HR_EMAIL=hr-admin@your-test-company.test
E2E_HR_PASSWORD=replace-me

# Public careers context the candidate journey walks through.
# This is the company's slug used in /:companySlug/careers.
E2E_COMPANY_SLUG=your-test-company

# Optional. If set, the candidate journey skips discovery and applies directly.
# Leave blank to let the tests discover/generate these:
#  - the HR journey writes a fresh screening link to the handoff file
#  - the candidate journey resolves the job via the careers page
E2E_JOB_ID=
E2E_SCREENING_LINK_ID=

# Optional demo-data controls.
# Leave E2E_DEMO_SEED blank for a fresh realistic scenario on every HR run.
# Set it to reuse the same job, candidate, and resume data while debugging.
E2E_DEMO_SEED=

# Defaults keep emails safely non-deliverable. Point this at a test inbox
# domain when you want to inspect candidate confirmation messages.
E2E_DEMO_EMAIL_DOMAIN=example.com
E2E_DEMO_EMAIL_PREFIX=candidate
